<% content_for(:title) { "오늘의 운세 - 1분 사주" } %>

<%
  element_emojis = { '목' => '🌳', '화' => '🔥', '토' => '⛰️', '금' => '⚔️', '수' => '💧' }
  daily = @daily
  yearly = @yearly
  trend = @analysis[:trend_2026]

  # 분야별 점수 (십성 기반, 랜덤하지 않음)
  base = daily[:score]
  cat_scores = {
    money: daily[:ten_god] == '정재' || daily[:ten_god] == '편재' ? [base + 8, 98].min : [base - 5, 98].min.clamp(40, 98),
    love: daily[:ten_god] == '정관' || daily[:ten_god] == '편관' ? [base + 6, 98].min : [base - 3, 98].min.clamp(40, 98),
    health: [base - (Date.today.day % 7), 98].min.clamp(40, 98),
    career: daily[:ten_god] == '정관' || daily[:ten_god] == '식신' ? [base + 5, 98].min : [base - 4, 98].min.clamp(40, 98),
    study: daily[:ten_god] == '정인' || daily[:ten_god] == '편인' ? [base + 7, 98].min : [base - 2, 98].min.clamp(40, 98)
  }
%>

<div class="page-header animate-fadeIn">
  <h1>오늘의 운세</h1>
  <p class="subtitle"><%= Date.today.strftime("%Y년 %m월 %d일") %> · <%= daily[:label] %></p>
</div>

<!-- Score -->
<div class="section-card fortune-score-card animate-fadeInUp">
  <div class="score-ring">
    <svg viewBox="0 0 120 120">
      <defs>
        <linearGradient id="scoreGradient" x1="0%" y1="0%" x2="100%" y2="0%">
          <stop offset="0%" style="stop-color:#FFB088"/>
          <stop offset="100%" style="stop-color:#E8775F"/>
        </linearGradient>
      </defs>
      <circle class="ring-bg" cx="60" cy="60" r="52"/>
      <circle class="ring-fill" cx="60" cy="60" r="52"
        stroke-dasharray="<%= (2 * Math::PI * 52).round %>"
        stroke-dashoffset="<%= ((1 - daily[:score] / 100.0) * 2 * Math::PI * 52).round %>"/>
    </svg>
    <div class="score-value"><%= daily[:score] %></div>
  </div>
  <p class="score-label">종합 운세 점수</p>
</div>

<!-- 2026 트렌드 코멘트 -->
<% if trend %>
  <section class="section-card highlight-card animate-fadeInUp">
    <h2 class="section-title">📌 오늘의 2026 트렌드 코멘트</h2>
    <p class="reading-text"><%= trend[:daily] %></p>
    <div class="term-tooltip">
      🗓️ 이달의 포인트: <%= trend[:monthly] %>
    </div>
  </section>
<% end %>

<!-- 분야별 운세 -->
<div class="section-card animate-fadeInUp">
  <h2 class="section-title">분야별 운세</h2>
  <%
    categories = [
      { emoji: '💰', label: '재물운', score: cat_scores[:money],
        desc: daily[:ten_god] == '정재' || daily[:ten_god] == '편재' ? '금전적 행운이 가까이! 재테크 앱을 확인해보세요 💳' : '꾸준한 노력이 빛을 발하는 날. 충동구매는 자제해요' },
      { emoji: '💕', label: '애정운', score: cat_scores[:love],
        desc: daily[:ten_god] == '정관' || daily[:ten_god] == '편관' ? '새로운 인연의 가능성! 온·오프라인 모임에서 좋은 만남이 기다려요' : '소중한 사람에게 따뜻한 연락 한 통, 관계가 더 깊어져요' },
      { emoji: '💪', label: '건강운', score: cat_scores[:health],
        desc: '수분 섭취와 스트레칭은 기본! 오늘은 특히 눈 건강에 신경 써주세요 👀' },
      { emoji: '💼', label: '직업운', score: cat_scores[:career],
        desc: daily[:ten_god] == '정관' ? 'AI 도구를 활용해보면 업무 효율이 2배! 상사에게 좋은 인상을 줄 수 있어요' : '새로운 아이디어를 메모해두세요. 의외로 큰 프로젝트로 이어질 수 있어요' },
      { emoji: '📚', label: '학업운', score: cat_scores[:study],
        desc: daily[:ten_god] == '정인' || daily[:ten_god] == '편인' ? '집중력 MAX! AI 학습 도구를 활용하면 효율이 극적으로 올라가요' : '새로운 분야에 관심을 가져보세요. 유튜브 강의도 좋아요' }
    ]
  %>

  <% categories.each do |cat| %>
    <div class="daily-category">
      <span class="emoji"><%= cat[:emoji] %></span>
      <div class="info">
        <div class="label"><%= cat[:label] %></div>
        <div class="desc"><%= cat[:desc] %></div>
      </div>
      <span class="score-badge <%= cat[:score] >= 80 ? 'score-high' : (cat[:score] >= 60 ? 'score-medium' : 'score-low') %>">
        <%= cat[:score] %>
      </span>
    </div>
  <% end %>
</div>

<!-- 행운 아이템 -->
<div class="section-card animate-fadeInUp">
  <h2 class="section-title">🍀 오늘의 행운</h2>
  <div class="lucky-items">
    <span class="lucky-tag">
      <span class="tag-emoji">🎨</span> <%= daily[:lucky][:color] %>
    </span>
    <span class="lucky-tag">
      <span class="tag-emoji">🔢</span> <%= daily[:lucky][:number] %>
    </span>
    <span class="lucky-tag">
      <span class="tag-emoji">🧭</span> <%= daily[:lucky][:direction] %>
    </span>
    <span class="lucky-tag">
      <span class="tag-emoji"><%= daily[:lucky][:element_emoji] %></span> <%= daily[:element] %>의 기운
    </span>
  </div>
</div>

<!-- 냥이의 한마디 -->
<section class="section-card animate-fadeInUp">
  <h2 class="section-title">🐱 냥이의 한마디</h2>
  <div class="info-note">
    오늘은 <strong><%= daily[:ten_god] %></strong>의 기운이 흐르는 날이야!
    <% case daily[:ten_god] %>
    <% when '식신' %> 
      맛있는 거 먹으면서 여유롭게 보내는 게 좋겠어~ 창의적인 아이디어가 떠오를 수도! 🎨
    <% when '상관' %> 
      표현력이 UP! 하고 싶은 말 시원하게 하되, SNS에 올리기 전 한번 더 생각해봐~ 😸
    <% when '정재' %> 
      돈이 들어올 조짐! 재테크 앱 확인해보고, 포인트 적립도 챙겨봐 💰
    <% when '편재' %> 
      뜻밖의 행운이! 이벤트 응모나 리워드 체크해봐~ 🎰
    <% when '정관' %> 
      책임감이 빛나는 날! AI 도구로 업무 효율을 높여보면 인정받을 수 있어 👔
    <% when '편관' %> 
      도전적인 하루! 불편한 일에 맞서면 성장할 수 있어 💪
    <% when '정인' %> 
      공부하기 좋은 날! 관심 있는 자격증이나 온라인 강의를 찾아볼 때 📚
    <% when '편인' %> 
      특별한 영감이 떠오르는 날! 새로운 앱이나 서비스를 탐색해봐 ✨
    <% when '비견' %> 
      친구들과 함께하면 기운이 UP! 커뮤니티 활동이나 모임에 참여해봐 👥
    <% when '겁재' %> 
      경쟁심이 불타는 날! 운동이나 게임에서 실력 발휘해봐 🏆
    <% else %>
      새로운 에너지가 시작되는 날이야! 긍정적인 마음으로 보내봐 ✨
    <% end %>
  </div>
  <% if trend && trend[:ten_god_advice] %>
    <div class="term-tooltip">
      📌 올해의 맥락: <%= trend[:ten_god_advice] %>
    </div>
  <% end %>
</section>

<!-- 올해의 운세 미리보기 -->
<section class="section-card animate-fadeInUp">
  <h2 class="section-title">📆 <%= yearly[:year] %>년 운세</h2>
  <p class="reading-text">
    올해는 <strong><%= yearly[:label] %></strong>!
    <%= yearly[:ten_god] %>의 기운이 한 해를 지배해요.
    <%= element_emojis[yearly[:element]] %> 
    <strong><%= yearly[:element] %></strong>의 에너지를 잘 활용해보세요~
  </p>
  <% if trend %>
    <div class="info-note">
      <strong>🐴 2026 병오년 포인트:</strong><br>
      <%= trend[:general] %>
    </div>
  <% end %>
  <a href="<%= yearly_fortune_path %>" class="action-btn primary mt-md" style="text-decoration: none; display: block; text-align: center;">
    📊 올해 운세 자세히 보기
  </a>
</section>

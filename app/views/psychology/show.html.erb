<% content_for(:title) { "심리 유형 결과 - 1분 사주" } %>
<% r = @result[:result] %>
<div class="page-header animate-fadeIn">
  <h1 style="color:<%= r[:color] %>; font-size:28px;"><%= r[:name] %></h1>
  <p class="subtitle">나의 심리 유형</p>
</div>
<div class="card animate-fadeInUp" style="text-align:center; padding:24px; border:2px solid <%= r[:color] %>30;">
  <p style="line-height:1.8; color:var(--text-2); font-size:15px;"><%= r[:desc] %></p>
  <div style="margin-top:16px; padding:14px; border-radius:12px; background:linear-gradient(135deg, <%= r[:color] %>15, <%= r[:color] %>05);">
    <div style="font-size:12px; color:var(--text-3); margin-bottom:4px;">💡 성장 조언</div>
    <p style="font-size:14px; line-height:1.7; color:var(--text-1);"><%= r[:advice] %></p>
  </div>
</div>
<div style="display:flex; gap:8px; margin-top:16px;">
  <a href="<%= new_psychology_path %>" class="btn-primary" style="flex:1; text-align:center; text-decoration:none;">🔄 다시 테스트</a>
  <a href="<%= root_path %>" class="btn-primary" style="flex:1; text-align:center; text-decoration:none; background:var(--bg-3); color:var(--text-1);">🏠 홈</a>
</div>

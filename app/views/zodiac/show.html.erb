<% content_for(:title) { "#{@sign_name} 별자리 운세 - 1분 사주" } %>

<%
  color = @sign_info[:color]
  score = @fortune[:score]
  score_color = case score
                when 80..100 then "#22c55e"
                when 65..79 then "#3b82f6"
                when 50..64 then "#a78bfa"
                else "#f59e0b"
                end
%>

<!-- 별자리 히어로 -->
<div class="card animate-fadeIn" style="text-align: center; padding: 32px 16px;">
  <div style="font-size: 4em; margin-bottom: 8px;"><%= @sign_info[:emoji] %></div>
  <h1 style="font-size: 1.6em; margin: 0 0 4px;"><%= @sign_name %></h1>
  <p class="text-muted text-small"><%= @sign_info[:planet] %> · <%= @sign_info[:element] %> 원소</p>
  <p style="margin-top: 12px; line-height: 1.7; font-size: 0.92em;"><%= @sign_info[:traits] %></p>
</div>

<!-- 오늘의 운세 점수 -->
<div class="card fortune-hero-card animate-fadeInUp">
  <div class="fortune-hero-header">
    <h3><%= @sign_info[:emoji] %> 오늘의 별자리 운세</h3>
    <span class="fortune-hero-date"><%= Date.today.strftime("%m/%d") %></span>
  </div>

  <div class="fortune-score-hero">
    <div class="score-ring-premium">
      <svg viewBox="0 0 140 140">
        <defs>
          <linearGradient id="zodiacGrad" x1="0%" y1="0%" x2="100%" y2="100%">
            <stop offset="0%" style="stop-color:<%= color %>"/>
            <stop offset="100%" style="stop-color:#AF8EF5"/>
          </linearGradient>
        </defs>
        <circle cx="70" cy="70" r="60" fill="none" stroke="#f0f0f5" stroke-width="8"/>
        <circle cx="70" cy="70" r="60" fill="none" stroke="url(#zodiacGrad)" stroke-width="8"
          stroke-linecap="round"
          stroke-dasharray="<%= (2 * Math::PI * 60).round %>"
          stroke-dashoffset="<%= ((1 - score / 100.0) * 2 * Math::PI * 60).round %>"
          transform="rotate(-90 70 70)"/>
      </svg>
      <div class="score-number"><%= score %></div>
      <div class="score-unit">점</div>
    </div>
    <div class="score-grade">
      <span class="grade-badge" style="background: <%= score_color %>18; color: <%= score_color %>; border: 1px solid <%= score_color %>30;">
        오늘의 무드: <%= @fortune[:mood] %>
      </span>
    </div>
  </div>
</div>

<!-- 운세 카테고리 -->
<div class="card animate-fadeInUp">
  <div class="section-header">
    <span class="emoji">🔮</span>
    <h3>오늘의 열쇠</h3>
  </div>
  <p style="line-height: 1.8;"><%= @fortune[:advice] %></p>
</div>

<div class="fortune-grid-premium animate-fadeInUp" style="margin-top: 12px;">
  <div class="fortune-item-premium">
    <span class="fortune-emoji">💕</span>
    <span class="fortune-label">연애</span>
    <span class="fortune-value" style="font-size: 0.8em; padding: 4px 8px;"><%= @fortune[:love_advice] %></span>
  </div>
  <div class="fortune-item-premium">
    <span class="fortune-emoji">💼</span>
    <span class="fortune-label">커리어</span>
    <span class="fortune-value" style="font-size: 0.8em; padding: 4px 8px;"><%= @fortune[:career_advice] %></span>
  </div>
</div>

<!-- 행운 정보 -->
<div class="card animate-fadeInUp">
  <div class="section-header">
    <span class="emoji">🍀</span>
    <h3>오늘의 행운</h3>
  </div>
  <div class="lucky-grid-premium">
    <div class="lucky-item-premium">
      <div class="lucky-icon-circle" style="background: <%= color %>;">🎨</div>
      <div class="lucky-detail">
        <span class="lucky-detail-label">행운의 색</span>
        <span class="lucky-detail-value" style="font-weight: 700;"><%= @fortune[:lucky_color] %></span>
      </div>
    </div>
    <div class="lucky-item-premium">
      <div class="lucky-icon-circle" style="background: #6366F1;">🔢</div>
      <div class="lucky-detail">
        <span class="lucky-detail-label">행운의 숫자</span>
        <span class="lucky-detail-value" style="font-weight: 700;"><%= @fortune[:lucky_number] %></span>
      </div>
    </div>
    <div class="lucky-item-premium">
      <div class="lucky-icon-circle" style="background: #EC4899;"><%= SajuEngine::ZodiacEngine::ZODIAC_SIGNS[@fortune[:best_match]][:emoji] %></div>
      <div class="lucky-detail">
        <span class="lucky-detail-label">최고의 궁합</span>
        <span class="lucky-detail-value" style="font-weight: 700;"><%= @fortune[:best_match] %></span>
      </div>
    </div>
  </div>
</div>

<!-- 별자리 성격 -->
<div class="card animate-fadeInUp">
  <div class="section-header">
    <span class="emoji">💕</span>
    <h3>연애 스타일</h3>
  </div>
  <p style="line-height: 1.8;"><%= @sign_info[:love] %></p>
</div>

<div class="card animate-fadeInUp">
  <div class="section-header">
    <span class="emoji">💼</span>
    <h3>추천 분야</h3>
  </div>
  <p style="line-height: 1.8;"><%= @sign_info[:career] %></p>
</div>

<!-- 12별자리 리스트 -->
<div class="card animate-fadeInUp">
  <div class="section-header">
    <span class="emoji">⭐</span>
    <h3>12별자리</h3>
  </div>
  <div style="display: grid; grid-template-columns: repeat(4, 1fr); gap: 8px; margin-top: 12px;">
    <% @all_signs.each do |name, info| %>
      <div style="text-align: center; padding: 12px 4px; border-radius: 12px; background: <%= name == @sign_name ? "#{info[:color]}15" : 'transparent' %>; border: 1px solid <%= name == @sign_name ? "#{info[:color]}40" : 'transparent' %>;">
        <div style="font-size: 1.5em;"><%= info[:emoji] %></div>
        <div style="font-size: 0.75em; margin-top: 4px; font-weight: <%= name == @sign_name ? '700' : '400' %>; color: <%= name == @sign_name ? info[:color] : '#888' %>;"><%= name %></div>
      </div>
    <% end %>
  </div>
</div>

<!-- 하단 액션 -->
<div class="quick-menu animate-fadeInUp">
  <a href="<%= root_path %>" class="quick-item">
    <div class="icon-circle">🏠</div>
    <span class="label">홈으로</span>
  </a>
  <a href="<%= new_saju_path %>" class="quick-item">
    <div class="icon-circle">🔮</div>
    <span class="label">사주풀이</span>
  </a>
  <a href="<%= new_dream_path %>" class="quick-item">
    <div class="icon-circle">🌙</div>
    <span class="label">꿈해몽</span>
  </a>
  <a href="<%= chat_path %>" class="quick-item">
    <div class="icon-circle">💬</div>
    <span class="label">AI 챗봇</span>
  </a>
</div>

<!-- 카카오 공유 -->
<div class="card text-center animate-fadeInUp" style="margin-top: 16px;">
  <button onclick="shareKakaoZodiac()" class="btn-kakao-share">
    💬 카카오톡으로 공유하기
  </button>
</div>

<script>
function shareKakaoZodiac() {
  if (typeof Kakao === 'undefined') { alert('카카오 SDK 로딩 중...'); return; }
  if (!Kakao.isInitialized()) Kakao.init('7d614af7b2a6e40d9c74c26cca5cf866');

  Kakao.Share.sendDefault({
    objectType: 'feed',
    content: {
      title: '<%= @sign_info[:emoji] %> <%= @sign_name %> 오늘의 운세: <%= score %>점!',
      description: '<%= @fortune[:advice].gsub("'", "\\\\'") %>',
      imageUrl: window.location.origin + '/icon.png',
      link: { mobileWebUrl: window.location.origin, webUrl: window.location.origin }
    },
    buttons: [{
      title: '내 별자리 운세 보기',
      link: { mobileWebUrl: window.location.origin + '/zodiac', webUrl: window.location.origin + '/zodiac' }
    }]
  });
}
</script>

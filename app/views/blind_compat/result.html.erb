<% content_for(:title) { "💕 블라인드 궁합 결과 - 1분 사주" } %>

<%
  score = @compatibility[:score]
  details = @compatibility[:details] || {}
  element1 = SajuEngine::HeavenlyStems.element(@person1[:saju][:day][:stem])
  element2 = SajuEngine::HeavenlyStems.element(@person2[:saju][:day][:stem])
  element_icons = { '목' => '🌿', '화' => '🔥', '토' => '🪨', '금' => '🪙', '수' => '💧' }
  element_names = { '목' => '나무', '화' => '불', '토' => '흙', '금' => '쇠', '수' => '물' }

  grade = case score
    when 85..100 then { text: '천생연분', emoji: '💕', color: '#ec4899' }
    when 70..84 then { text: '찰떡궁합', emoji: '🥰', color: '#8b5cf6' }
    when 55..69 then { text: '괜찮은 사이', emoji: '😊', color: '#3b82f6' }
    when 40..54 then { text: '노력하면 OK', emoji: '🤔', color: '#f59e0b' }
    else { text: '극과 극?!', emoji: '😱', color: '#ef4444' }
    end
%>

<% content_for(:head) do %>
<style>
/* 숏폼 궁합 결과 UI */
.bc-viewport {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  z-index: 9999;
  background: #000;
  overflow: hidden;
}
.bc-progress {
  position: absolute;
  top: 12px; left: 12px; right: 12px;
  display: flex;
  gap: 4px;
  z-index: 10002;
}
.bc-progress-seg {
  flex: 1; height: 3px;
  background: rgba(255,255,255,0.25);
  border-radius: 2px;
  overflow: hidden;
}
.bc-progress-fill {
  height: 100%; width: 0%;
  background: #fff;
  border-radius: 2px;
  transition: width 0.3s ease;
}
.bc-progress-seg.done .bc-progress-fill { width: 100%; }
.bc-progress-seg.active .bc-progress-fill { width: 100%; }

.bc-cards { position: relative; width: 100%; height: 100%; }
.bc-card {
  position: absolute;
  top: 0; left: 0;
  width: 100%; height: 100%;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  padding: 50px 24px 60px;
  opacity: 0;
  transform: scale(0.95);
  transition: opacity 0.4s ease, transform 0.4s ease;
  pointer-events: none;
  overflow-y: auto;
  -webkit-overflow-scrolling: touch;
  box-sizing: border-box;
}
.bc-card.active { opacity: 1; transform: scale(1); pointer-events: auto; }

.bc-card[data-card="0"] { background: linear-gradient(160deg, #1a0530, #ec4899, #8b5cf6); }
.bc-card[data-card="1"] { background: linear-gradient(160deg, #0f0c29, #302b63, #24243e); }
.bc-card[data-card="2"] { background: linear-gradient(160deg, #834d9b, #d04ed6); }
.bc-card[data-card="3"] { background: linear-gradient(160deg, #0d7377, #14ffec10); }
.bc-card[data-card="4"] { background: linear-gradient(160deg, #eb3349, #f45c43, #f09819); }

.bc-tap-left, .bc-tap-right {
  position: absolute; top: 40px; bottom: 0; z-index: 10001; cursor: pointer;
}
.bc-tap-left { left: 0; width: 35%; }
.bc-tap-right { right: 0; width: 65%; }

.bc-close {
  position: absolute; top: 28px; right: 16px; z-index: 10003;
  background: rgba(0,0,0,0.35); border: none; color: #fff;
  width: 32px; height: 32px; border-radius: 50%; font-size: 16px;
  cursor: pointer; display: flex; align-items: center; justify-content: center;
  backdrop-filter: blur(4px);
}
.bc-counter {
  position: absolute; top: 30px; left: 16px; z-index: 10003;
  color: rgba(255,255,255,0.7); font-size: 12px; font-weight: 600;
}

.bc-content { width: 100%; max-width: 420px; text-align: center; color: #fff; }
.bc-emoji-hero { font-size: 64px; margin-bottom: 16px; animation: bcBounce 0.6s ease; }
.bc-title { font-size: 28px; font-weight: 900; margin-bottom: 8px; line-height: 1.3; text-shadow: 0 2px 12px rgba(0,0,0,0.3); }
.bc-subtitle { font-size: 15px; color: rgba(255,255,255,0.75); margin-bottom: 20px; line-height: 1.5; }
.bc-badge { display: inline-block; padding: 6px 16px; border-radius: 20px; font-size: 13px; font-weight: 700; background: rgba(255,255,255,0.15); color: #fff; backdrop-filter: blur(8px); border: 1px solid rgba(255,255,255,0.2); margin: 4px; }
.bc-text { font-size: 15px; line-height: 1.8; color: rgba(255,255,255,0.9); text-align: left; background: rgba(0,0,0,0.2); border-radius: 16px; padding: 16px 20px; margin-top: 16px; backdrop-filter: blur(4px); }
.bc-divider { width: 40px; height: 3px; background: rgba(255,255,255,0.3); border-radius: 2px; margin: 20px auto; }

/* 점수 링 */
.bc-score-ring { position: relative; width: 160px; height: 160px; margin: 0 auto 16px; }
.bc-score-ring svg { width: 100%; height: 100%; }
.bc-score-num { position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%); font-size: 48px; font-weight: 900; }
.bc-score-unit { position: absolute; top: 50%; left: 50%; transform: translate(-50%, 24px); font-size: 14px; color: rgba(255,255,255,0.6); }

/* VS 카드 */
.bc-vs { display: flex; align-items: center; justify-content: center; gap: 16px; margin-top: 20px; }
.bc-vs-person { text-align: center; flex: 1; }
.bc-vs-icon { font-size: 40px; margin-bottom: 6px; }
.bc-vs-name { font-size: 15px; font-weight: 700; }
.bc-vs-el { font-size: 12px; color: rgba(255,255,255,0.6); margin-top: 4px; }
.bc-vs-heart { font-size: 28px; animation: bcPulse 1.5s ease infinite; }

/* 상세 항목 */
.bc-detail-grid { display: flex; flex-direction: column; gap: 10px; margin-top: 16px; width: 100%; }
.bc-detail-item { display: flex; align-items: center; gap: 12px; background: rgba(255,255,255,0.08); border-radius: 14px; padding: 14px 16px; backdrop-filter: blur(4px); }
.bc-detail-emoji { font-size: 24px; }
.bc-detail-info { text-align: left; flex: 1; }
.bc-detail-label { font-size: 13px; color: rgba(255,255,255,0.6); display: block; }
.bc-detail-value { font-size: 15px; font-weight: 700; }

/* CTA */
.bc-cta-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; margin-top: 20px; width: 100%; }
.bc-cta-btn { display: flex; align-items: center; justify-content: center; gap: 6px; padding: 14px; border-radius: 14px; background: rgba(255,255,255,0.12); color: #fff; text-decoration: none; font-size: 14px; font-weight: 600; border: 1px solid rgba(255,255,255,0.15); backdrop-filter: blur(8px); transition: all 0.2s; cursor: pointer; }
.bc-cta-btn:hover { background: rgba(255,255,255,0.2); transform: scale(1.02); }
.bc-cta-btn.primary { background: rgba(255,255,255,0.2); grid-column: 1 / -1; }

.bc-tap-hint { position: absolute; bottom: 20px; left: 50%; transform: translateX(-50%); color: rgba(255,255,255,0.4); font-size: 12px; animation: bcPulse 2s ease infinite; z-index: 10002; }

.bc-animate { animation: bcSlideUp 0.5s ease both; }
.bc-animate-d1 { animation-delay: 0.1s; }
.bc-animate-d2 { animation-delay: 0.2s; }
.bc-animate-d3 { animation-delay: 0.3s; }

@keyframes bcBounce { 0% { transform: scale(0.3); opacity: 0; } 50% { transform: scale(1.1); } 100% { transform: scale(1); opacity: 1; } }
@keyframes bcPulse { 0%, 100% { opacity: 0.4; transform: scale(1); } 50% { opacity: 1; transform: scale(1.1); } }
@keyframes bcSlideUp { from { transform: translateY(20px); opacity: 0; } to { transform: translateY(0); opacity: 1; } }

@media (min-width: 769px) {
  .bc-viewport { display: flex; justify-content: center; }
  .bc-cards { max-width: 420px; border-radius: 20px; overflow: hidden; margin: 20px auto; height: calc(100% - 40px); box-shadow: 0 0 60px rgba(0,0,0,0.5); }
  .bc-progress { left: calc(50% - 198px); right: calc(50% - 198px); }
  .bc-close { right: calc(50% - 198px); }
  .bc-counter { left: calc(50% - 198px); }
}
</style>
<% end %>

<div class="bc-viewport" id="bcViewport">
  <div class="bc-progress">
    <% 5.times do |i| %>
      <div class="bc-progress-seg" data-seg="<%= i %>"><div class="bc-progress-fill"></div></div>
    <% end %>
  </div>
  <div class="bc-counter" id="bcCounter">1 / 5</div>
  <button class="bc-close" onclick="location.href='<%= root_path %>'">✕</button>
  <div class="bc-tap-left" id="bcTapLeft"></div>
  <div class="bc-tap-right" id="bcTapRight"></div>

  <div class="bc-cards">
    <!-- 카드 1: 궁합 점수 -->
    <div class="bc-card active" data-card="0">
      <div class="bc-content">
        <div class="bc-emoji-hero"><%= grade[:emoji] %></div>
        <div class="bc-score-ring bc-animate">
          <svg viewBox="0 0 160 160">
            <defs>
              <linearGradient id="bcScoreGrad" x1="0%" y1="0%" x2="100%" y2="100%">
                <stop offset="0%" style="stop-color:#ec4899"/>
                <stop offset="100%" style="stop-color:#8b5cf6"/>
              </linearGradient>
            </defs>
            <circle cx="80" cy="80" r="70" fill="none" stroke="rgba(255,255,255,0.1)" stroke-width="8"/>
            <circle cx="80" cy="80" r="70" fill="none" stroke="url(#bcScoreGrad)" stroke-width="8"
              stroke-linecap="round"
              stroke-dasharray="<%= (2 * Math::PI * 70).round %>"
              stroke-dashoffset="<%= ((1 - score / 100.0) * 2 * Math::PI * 70).round %>"
              transform="rotate(-90 80 80)"/>
          </svg>
          <div class="bc-score-num"><%= score %></div>
          <div class="bc-score-unit">점</div>
        </div>
        <h1 class="bc-title bc-animate bc-animate-d1" style="color: <%= grade[:color] %>"><%= grade[:text] %></h1>
        <p class="bc-subtitle bc-animate bc-animate-d2"><%= @compatibility[:summary] %></p>
        <div class="bc-vs bc-animate bc-animate-d3">
          <div class="bc-vs-person">
            <div class="bc-vs-icon"><%= element_icons[element1] %></div>
            <div class="bc-vs-name"><%= @name1 %></div>
            <div class="bc-vs-el"><%= element_names[element1] %> 타입</div>
          </div>
          <div class="bc-vs-heart">💕</div>
          <div class="bc-vs-person">
            <div class="bc-vs-icon"><%= element_icons[element2] %></div>
            <div class="bc-vs-name"><%= @name2 %></div>
            <div class="bc-vs-el"><%= element_names[element2] %> 타입</div>
          </div>
        </div>
      </div>
      <div class="bc-tap-hint">탭해서 넘기기 →</div>
    </div>

    <!-- 카드 2: 오행 조화 -->
    <div class="bc-card" data-card="1">
      <div class="bc-content">
        <div class="bc-emoji-hero">⚖️</div>
        <h2 class="bc-title bc-animate">오행 조화 분석</h2>
        <p class="bc-subtitle bc-animate bc-animate-d1">두 사람의 에너지가 만나면?</p>
        <div class="bc-vs bc-animate bc-animate-d2">
          <div class="bc-vs-person">
            <div class="bc-vs-icon" style="font-size: 48px;"><%= element_icons[element1] %></div>
            <div class="bc-vs-name"><%= element_names[element1] %></div>
          </div>
          <div style="font-size: 24px;">➕</div>
          <div class="bc-vs-person">
            <div class="bc-vs-icon" style="font-size: 48px;"><%= element_icons[element2] %></div>
            <div class="bc-vs-name"><%= element_names[element2] %></div>
          </div>
        </div>
        <div class="bc-text bc-animate bc-animate-d3">
          <%= @compatibility[:element_harmony] || "두 사람의 오행이 서로를 보완하며 조화를 이뤄요. #{element_names[element1]}과 #{element_names[element2]}의 에너지가 만나 새로운 시너지를 만들어냅니다!" %>
        </div>
      </div>
    </div>

    <!-- 카드 3: 연애 궁합 -->
    <div class="bc-card" data-card="2">
      <div class="bc-content">
        <div class="bc-emoji-hero">💕</div>
        <h2 class="bc-title bc-animate">연애 궁합</h2>
        <p class="bc-subtitle bc-animate bc-animate-d1">두 사람의 사랑 케미스트리</p>
        <div class="bc-detail-grid bc-animate bc-animate-d2">
          <% [
            { emoji: '💘', label: '첫인상', value: details[:first_impression] || '강한 끌림' },
            { emoji: '💬', label: '대화 궁합', value: details[:communication] || '통하는 편' },
            { emoji: '🔥', label: '감정 교류', value: details[:emotional] || '열정적' },
            { emoji: '🤝', label: '신뢰도', value: details[:trust] || '높은 편' }
          ].each do |item| %>
            <div class="bc-detail-item">
              <span class="bc-detail-emoji"><%= item[:emoji] %></span>
              <div class="bc-detail-info">
                <span class="bc-detail-label"><%= item[:label] %></span>
                <span class="bc-detail-value"><%= item[:value] %></span>
              </div>
            </div>
          <% end %>
        </div>
        <div class="bc-text bc-animate bc-animate-d3">
          <%= @compatibility[:love_analysis] || "#{@name1}과 #{@name2}의 연애 스타일이 서로를 자극하며 성장하는 관계예요. 서로의 차이를 이해하면 더욱 깊은 사랑이 될 수 있어요!" %>
        </div>
      </div>
    </div>

    <!-- 카드 4: 친구/비즈니스 궁합 -->
    <div class="bc-card" data-card="3">
      <div class="bc-content">
        <div class="bc-emoji-hero">🤝</div>
        <h2 class="bc-title bc-animate">친구 & 비즈니스 궁합</h2>
        <p class="bc-subtitle bc-animate bc-animate-d1">함께 하면 더 좋을까?</p>
        <div class="bc-detail-grid bc-animate bc-animate-d2">
          <% [
            { emoji: '🏆', label: '팀워크', value: details[:teamwork] || '보통' },
            { emoji: '💡', label: '아이디어 시너지', value: details[:creativity] || '좋음' },
            { emoji: '⚡', label: '갈등 가능성', value: details[:conflict] || '낮은 편' },
            { emoji: '🎯', label: '목표 달성', value: details[:goal] || '높은 편' }
          ].each do |item| %>
            <div class="bc-detail-item">
              <span class="bc-detail-emoji"><%= item[:emoji] %></span>
              <div class="bc-detail-info">
                <span class="bc-detail-label"><%= item[:label] %></span>
                <span class="bc-detail-value"><%= item[:value] %></span>
              </div>
            </div>
          <% end %>
        </div>
        <div class="bc-text bc-animate bc-animate-d3">
          <%= @compatibility[:friend_analysis] || "두 사람이 함께하면 서로의 부족한 부분을 채워줄 수 있어요. 특히 #{element_names[element1]}의 추진력과 #{element_names[element2]}의 안정감이 시너지를 만들어요!" %>
        </div>
      </div>
    </div>

    <!-- 카드 5: 팩폭 + CTA -->
    <div class="bc-card" data-card="4">
      <div class="bc-content">
        <div class="bc-emoji-hero">💥</div>
        <h2 class="bc-title bc-animate">1분 팩폭!</h2>
        <p class="bc-subtitle bc-animate bc-animate-d1"><%= @name1 %> ❤️ <%= @name2 %>에게</p>
        <div class="bc-text bc-animate bc-animate-d2" style="font-size: 16px; text-align: center; line-height: 2;">
          <%= @compatibility[:advice] || "두 사람의 궁합은 노력하면 더 좋아질 수 있어요! 서로의 차이를 존중하고, 공통 관심사를 늘려가면 최고의 파트너가 될 수 있답니다 💕" %>
        </div>
        <div class="bc-divider"></div>
        <div class="bc-cta-grid bc-animate bc-animate-d3">
          <button onclick="shareResult()" class="bc-cta-btn primary" style="background: #FEE500; color: #3C1E1E;">💬 카톡으로 결과 공유</button>
          <a href="<%= new_blind_compat_path %>" class="bc-cta-btn">💕 다른 사람과 궁합</a>
          <a href="<%= new_saju_path %>" class="bc-cta-btn">🔮 사주풀이</a>
          <a href="<%= root_path %>" class="bc-cta-btn primary" style="background: linear-gradient(135deg, #ec489930, #8b5cf630);">🏠 홈으로</a>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
(function() {
  const totalCards = 5;
  let current = 0, isAnimating = false;
  const cards = document.querySelectorAll('.bc-card');
  const segs = document.querySelectorAll('.bc-progress-seg');
  const counter = document.getElementById('bcCounter');

  function goTo(i) {
    if (isAnimating || i < 0 || i >= totalCards) return;
    isAnimating = true;
    cards[current].classList.remove('active');
    setTimeout(() => { current = i; updateUI(); isAnimating = false; }, 300);
  }
  function updateUI() {
    cards.forEach((c, i) => c.classList.toggle('active', i === current));
    segs.forEach((s, i) => { s.classList.remove('done','active'); if (i < current) s.classList.add('done'); if (i === current) s.classList.add('active'); });
    counter.textContent = (current + 1) + ' / ' + totalCards;
    cards[current].scrollTop = 0;
  }

  document.getElementById('bcTapRight').addEventListener('click', () => goTo(current + 1));
  document.getElementById('bcTapLeft').addEventListener('click', () => goTo(current - 1));

  document.addEventListener('keydown', (e) => {
    if (e.key === 'ArrowRight' || e.key === ' ') goTo(current + 1);
    if (e.key === 'ArrowLeft') goTo(current - 1);
  });

  let tx = 0;
  document.getElementById('bcViewport').addEventListener('touchstart', (e) => { tx = e.changedTouches[0].clientX; }, { passive: true });
  document.getElementById('bcViewport').addEventListener('touchend', (e) => {
    const dx = e.changedTouches[0].clientX - tx;
    if (Math.abs(dx) > 50) { dx < 0 ? goTo(current + 1) : goTo(current - 1); }
  }, { passive: true });

  updateUI();
})();

function shareResult() {
  const url = window.location.href;
  if (navigator.share) {
    navigator.share({ title: '💕 블라인드 궁합 결과', text: '<%= @name1 %>과 <%= @name2 %>의 궁합은 <%= score %>점!', url: url });
  } else {
    navigator.clipboard.writeText(url).then(() => alert('결과 링크가 복사됐어! 💕'));
  }
}
</script>

<% content_for(:title) { "#{@person1_name}님이 궁합이 궁금하대! - 1분 사주" } %>

<div class="page-header animate-fadeIn">
  <div style="font-size: 64px; margin-bottom: 8px;">💘</div>
  <h1><%= @person1_name %>님이<br>너의 궁합이 궁금하대!</h1>
  <p class="subtitle">생일만 입력하면 1분 안에 결과가 나와! 🔥</p>
</div>

<div class="card animate-fadeInUp" style="text-align: center; padding: 20px;">
  <div style="background: linear-gradient(135deg, #ec489920, #8b5cf620); border-radius: 16px; padding: 16px; margin-bottom: 16px;">
    <div style="font-size: 14px; color: var(--text-2); line-height: 1.8;">
      🤫 상대방은 너의 생일을 <strong>모른 채</strong> 궁합 링크를 보냈어!<br>
      생일을 입력하면 양쪽 모두에게<br>
      💥 <strong>팩폭 궁합 결과</strong>가 공개돼!
    </div>
  </div>
</div>

<%= form_tag blind_match_path(token: @link.token), method: :post do %>
  <div class="person-section animate-fadeInUp">
    <div class="person-title">
      😊 나의 정보
    </div>

    <div class="form-section">
      <label class="form-label">💌 닉네임 (상대에게 표시됨)</label>
      <input type="text" name="nickname" class="form-control" placeholder="예: 썸녀, 귀요미, 익명" maxlength="10" style="margin-bottom: 12px;">
    </div>

    <div class="form-section">
      <label class="form-label">📅 생년월일</label>
      <div class="form-row">
        <div class="form-group">
          <select name="year" class="form-control" required>
            <option value="">년도</option>
            <% (1940..2025).reverse_each do |y| %>
              <option value="<%= y %>" <%= 'selected' if y == 2000 %>><%= y %>년</option>
            <% end %>
          </select>
        </div>
        <div class="form-group">
          <select name="month" class="form-control" required>
            <option value="">월</option>
            <% (1..12).each do |m| %>
              <option value="<%= m %>"><%= m %>월</option>
            <% end %>
          </select>
        </div>
        <div class="form-group">
          <select name="day" class="form-control" required>
            <option value="">일</option>
            <% (1..31).each do |d| %>
              <option value="<%= d %>"><%= d %>일</option>
            <% end %>
          </select>
        </div>
      </div>
    </div>

    <div class="form-row">
      <div class="form-group">
        <label class="form-label">🕐 태어난 시간</label>
        <select name="hour" class="form-control" required>
          <option value="0">자시 🐭</option>
          <option value="1">축시 🐮</option>
          <option value="3">인시 🐯</option>
          <option value="5">묘시 🐰</option>
          <option value="7">진시 🐲</option>
          <option value="9">사시 🐍</option>
          <option value="11" selected>오시 🐴</option>
          <option value="13">미시 🐑</option>
          <option value="15">신시 🐵</option>
          <option value="17">유시 🐔</option>
          <option value="19">술시 🐶</option>
          <option value="21">해시 🐷</option>
        </select>
      </div>
      <div class="form-group">
        <label class="form-label">👤 성별</label>
        <select name="gender" class="form-control">
          <option value="여">🙋‍♀️ 여자</option>
          <option value="남">🙋‍♂️ 남자</option>
        </select>
      </div>
    </div>
  </div>

  <button type="submit" class="btn-primary mt-md" style="background: linear-gradient(135deg, #ec4899, #8b5cf6);">
    💥 궁합 결과 확인하기!
  </button>
<% end %>

<% content_for(:title) { "띠운세 - 1분 사주" } %>
<div class="page-header animate-fadeIn">
  <h1>🐲 오늘의 띠운세</h1>
  <p class="subtitle"><%= @date.strftime("%Y년 %m월 %d일") %></p>
</div>
<% @tti_fortunes.each do |tf| %>
  <div class="card animate-fadeInUp" style="padding:16px;">
    <div style="display:flex; align-items:center; gap:12px;">
      <div style="font-size:36px;"><%= tf[:data][:emoji] %></div>
      <div style="flex:1;">
        <div style="font-weight:800; font-size:16px;"><%= tf[:data][:name] %></div>
        <div style="font-size:11px; color:var(--text-3);"><%= tf[:data][:years] %></div>
      </div>
      <div style="font-weight:900; font-size:18px; color:var(--primary);"><%= tf[:score] %>점</div>
    </div>
    <p style="font-size:13px; color:var(--text-2); margin-top:8px; line-height:1.6;"><%= tf[:fortune] %></p>
  </div>
<% end %>

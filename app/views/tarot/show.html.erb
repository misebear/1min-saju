<% content_for(:title) { "타로 결과 - 1분 사주" } %>
<div class="page-header animate-fadeIn">
  <h1>🃏 <%= @result[:spread][:name] %></h1>
  <p class="subtitle">카드가 전하는 메시지</p>
</div>
<% @result[:cards].each_with_index do |reading, i| %>
  <div class="card animate-fadeInUp" style="text-align:center; padding:20px;">
    <div style="font-size:12px; color:var(--text-3); margin-bottom:4px;">카드 <%= i + 1 %></div>
    <div style="font-size:48px; margin-bottom:8px;"><%= reading[:card][:emoji] %></div>
    <h2 style="font-size:22px; margin-bottom:4px;"><%= reading[:card][:name] %></h2>
    <span style="display:inline-block; padding:4px 12px; border-radius:12px; font-size:12px; font-weight:600; background:<%= reading[:card][:reversed] ? '#ef444420' : '#22c55e20' %>; color:<%= reading[:card][:reversed] ? '#ef4444' : '#22c55e' %>;"><%= reading[:direction] %></span>
    <div style="font-size:13px; color:var(--text-3); margin-top:4px;"><%= reading[:position] %></div>
    <p style="margin-top:12px; line-height:1.7; color:var(--text-2);"><%= reading[:meaning] %></p>
  </div>
<% end %>
<div class="card animate-fadeInUp" style="text-align:center; background:linear-gradient(135deg, #8b5cf620, #ec489920); padding:20px;">
  <div style="font-size:32px; margin-bottom:8px;">✨</div>
  <h3>종합 리딩</h3>
  <p style="margin-top:8px; line-height:1.8; color:var(--text-2);"><%= @result[:overall] %></p>
</div>
<a href="<%= new_tarot_path %>" class="btn-primary mt-md" style="display:block; text-align:center; text-decoration:none;">🃏 다시 뽑기</a>

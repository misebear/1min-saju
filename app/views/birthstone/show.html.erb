<% content_for(:title) { "탄생석 - 1분 사주" } %>
<% s = @result[:stone] %>
<div class="page-header animate-fadeIn">
  <div style="font-size:64px;"><%= s[:emoji] %></div>
  <h1><%= @result[:month] %>월의 탄생석</h1>
</div>
<div class="card animate-fadeInUp" style="text-align:center; padding:24px; border:2px solid <%= s[:color] %>40;">
  <h2 style="color:<%= s[:color] %>; font-size:28px;"><%= s[:name] %></h2>
  <div style="font-size:14px; color:var(--text-3); margin:4px 0;"><%= s[:meaning] %></div>
  <p style="margin-top:12px; line-height:1.8; color:var(--text-2);"><%= s[:desc] %></p>
</div>
<div class="card animate-fadeInUp">
  <h3>🍀 행운</h3><p style="color:var(--text-2); line-height:1.7;"><%= s[:luck] %></p>
</div>
<div class="card animate-fadeInUp">
  <h3>⚡ 파워</h3><p style="color:var(--text-2); line-height:1.7;"><%= s[:power] %></p>
</div>
<div class="card animate-fadeInUp">
  <h3>💕 궁합 좋은 탄생석</h3>
  <div style="display:flex; align-items:center; gap:12px; margin-top:8px;">
    <span style="font-size:32px;"><%= @result[:partner_stone][:emoji] %></span>
    <div><div style="font-weight:700;"><%= @result[:partner_month] %>월 — <%= @result[:partner_stone][:name] %></div>
    <div style="font-size:12px; color:var(--text-3);"><%= @result[:zodiac_match] %></div></div>
  </div>
</div>
<div class="card animate-fadeInUp">
  <h3>🔢 행운의 숫자</h3>
  <div style="display:flex; gap:8px; margin-top:8px;">
    <% @result[:lucky_numbers].each do |n| %>
      <span style="display:inline-flex; width:36px; height:36px; border-radius:50%; background:<%= s[:color] %>; color:#fff; font-weight:700; align-items:center; justify-content:center;"><%= n %></span>
    <% end %>
  </div>
</div>

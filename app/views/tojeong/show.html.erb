<% content_for(:title) { "#{@result[:year]}년 토정비결 - 1분 사주" } %>
<div class="page-header animate-fadeIn">
  <h1>🏛️ <%= @result[:year] %>년 토정비결</h1>
  <p class="subtitle"><%= @result[:sang_gwe][:name] %> · <%= @result[:jung_gwe][:name] %> · <%= @result[:ha_gwe][:name] %></p>
</div>
<div class="card animate-fadeInUp" style="text-align:center;">
  <div style="font-size:48px;"><%= @result[:total_grade][:emoji] %></div>
  <h2 style="color:<%= @result[:total_grade][:color] %>; font-size:28px; margin:8px 0;"><%= @result[:total_grade][:text] %></h2>
  <div style="font-size:36px; font-weight:900;"><%= @result[:total_score] %>점</div>
  <p style="color:var(--text-2); margin-top:12px; line-height:1.8;"><%= @result[:summary] %></p>
</div>
<div class="card animate-fadeInUp">
  <h3>📊 분야별 운세</h3>
  <% @result[:categories].each do |key, cat| %>
    <div style="display:flex; align-items:center; gap:10px; padding:10px 0; border-bottom:1px solid var(--border);">
      <span style="font-size:24px;"><%= cat[:emoji] %></span>
      <div style="flex:1;"><div style="font-weight:700;"><%= cat[:name] %></div><div style="font-size:12px; color:var(--text-3);"><%= cat[:advice] %></div></div>
      <div style="font-weight:800; color:var(--primary);"><%= cat[:score] %>점</div>
    </div>
  <% end %>
</div>
<div class="card animate-fadeInUp">
  <h3>📅 월별 운세</h3>
  <% @result[:monthly].each do |m| %>
    <div style="display:flex; align-items:center; gap:10px; padding:8px 0; border-bottom:1px solid var(--border);">
      <span style="font-size:18px;"><%= m[:emoji] %></span>
      <div style="font-weight:700; min-width:40px;"><%= m[:month] %>월</div>
      <div style="flex:1; font-size:13px; color:var(--text-2);"><%= m[:fortune] %></div>
      <div style="font-weight:700; font-size:13px;"><%= m[:score] %>점</div>
    </div>
  <% end %>
</div>

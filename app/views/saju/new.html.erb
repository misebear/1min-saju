<% content_for(:title) { "사주풀이 입력 - 1분 사주" } %>

<div class="page-header animate-fadeIn">
  <%= image_tag "snowcat/icon_cat_snowcat_1771225044956.png", class: "snowcat-mascot", alt: "1분 사주" %>
  <h1>사주풀이</h1>
  <p class="subtitle">태어난 날짜와 시간을 알려줘! 🐱</p>
</div>

<%= form_tag saju_path, method: :post, class: "animate-fadeInUp" do %>
  <!-- 생년월일 -->
  <div class="form-section">
    <label class="form-label">📅 생년월일</label>
    <div class="form-row">
      <div class="form-group">
        <select name="year" class="form-control" required>
          <option value="">년도</option>
          <% (1940..2025).reverse_each do |y| %>
            <option value="<%= y %>" <%= 'selected' if y == 2000 %>><%= y %>년</option>
          <% end %>
        </select>
      </div>
      <div class="form-group">
        <select name="month" class="form-control" required>
          <option value="">월</option>
          <% (1..12).each do |m| %>
            <option value="<%= m %>"><%= m %>월</option>
          <% end %>
        </select>
      </div>
      <div class="form-group">
        <select name="day" class="form-control" required>
          <option value="">일</option>
          <% (1..31).each do |d| %>
            <option value="<%= d %>"><%= d %>일</option>
          <% end %>
        </select>
      </div>
    </div>
  </div>

  <!-- 태어난 시간 -->
  <div class="form-section">
    <label class="form-label">🕐 태어난 시간</label>
    <select name="hour" class="form-control" required>
      <option value="">시간을 선택하세요</option>
      <option value="0">자시 (23:00~01:00) 🐭</option>
      <option value="1">축시 (01:00~03:00) 🐮</option>
      <option value="3">인시 (03:00~05:00) 🐯</option>
      <option value="5">묘시 (05:00~07:00) 🐰</option>
      <option value="7">진시 (07:00~09:00) 🐲</option>
      <option value="9">사시 (09:00~11:00) 🐍</option>
      <option value="11">오시 (11:00~13:00) 🐴</option>
      <option value="13">미시 (13:00~15:00) 🐑</option>
      <option value="15">신시 (15:00~17:00) 🐵</option>
      <option value="17">유시 (17:00~19:00) 🐔</option>
      <option value="19">술시 (19:00~21:00) 🐶</option>
      <option value="21">해시 (21:00~23:00) 🐷</option>
    </select>
  </div>

  <!-- 출생지 -->
  <div class="form-section">
    <label class="form-label">📍 출생지 <span class="term-note">지역 시차 + 서머타임 자동 보정에 사용돼요</span></label>
    <select name="city" class="form-control">
      <% @city_options.each do |label, key| %>
        <option value="<%= key %>" <%= 'selected' if key == '서울' %>><%= label %></option>
      <% end %>
    </select>
  </div>

  <!-- 성별 -->
  <div class="form-section">
    <label class="form-label">👤 성별</label>
    <div class="gender-toggle">
      <label class="gender-btn active" id="gender-male" onclick="selectGender('남', this)">
        <input type="radio" name="gender" value="남" checked>
        🙋‍♂️ 남자
      </label>
      <label class="gender-btn" id="gender-female" onclick="selectGender('여', this)">
        <input type="radio" name="gender" value="여">
        🙋‍♀️ 여자
      </label>
    </div>
  </div>

  <div class="divider"></div>

  <button type="submit" class="btn-primary">
    🔮 사주 풀어보기
  </button>
<% end %>

<div class="card mt-lg animate-fadeInUp">
  <div class="section-header">
    <%= image_tag "snowcat/icon_dog_snowcat_1771224888733.png", class: "snowcat-mascot snowcat-mascot-sm", alt: "사주멍이" %>
    <h3>알아두면 좋은 꿀팁!</h3>
  </div>
  <p class="text-small text-muted" style="line-height: 1.8;">
    💡 정확한 태어난 시간을 입력하면 더 정확한 사주풀이를 받을 수 있어!<br>
    📝 태어난 시간을 모르면 가장 가까운 시간대를 선택해도 괜찮아~<br>
    🌙 사주는 음양오행(나무, 불, 흙, 쇠, 물)의 조화로 너의 운명을 읽어내는 거야!
  </p>
</div>

<script>
function selectGender(value, el) {
  document.querySelectorAll('.gender-btn').forEach(b => b.classList.remove('active'));
  el.classList.add('active');
  el.querySelector('input').checked = true;
}
</script>

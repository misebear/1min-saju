<% content_for(:title) { "나의 사주팔자 - 1분 사주" } %>

<%
  saju = @analysis[:saju]
  distribution = saju[:distribution]
  balance = saju[:balance]
  element_class = { '목' => 'wood', '화' => 'fire', '토' => 'earth', '금' => 'metal', '수' => 'water' }
  element_names = { '목' => '나무', '화' => '불', '토' => '흙', '금' => '쇠', '수' => '물' }
  element_icons = { '목' => '🌿', '화' => '🔥', '토' => '🪨', '금' => '🪙', '수' => '💧' }
  pillar_names = ['년주', '월주', '일주', '시주']
  pillars = [saju[:year], saju[:month], saju[:day], saju[:hour]]
%>

<!-- Page Title -->
<div class="result-header">
  <h1>사주 분석 결과</h1>
  <div class="result-subtitle">
    <span class="badge"><%= saju[:zodiac_emoji] %> <%= saju[:zodiac] %>띠</span>
    <span class="badge">일간 <%= saju[:day_master] %>(<%= SajuEngine::HeavenlyStems.element(saju[:day_master]) %>)</span>
  </div>
</div>

<!-- 시간 보정 정보 -->
<% if @correction && @correction[:applied] %>
  <div class="correction-banner">
    <div class="correction-title">🔧 시간 보정 적용됨</div>
    <div class="correction-details">
      <% @correction[:corrections].each do |c| %>
        <span class="correction-chip"><%= c[:label] %></span>
      <% end %>
      <% if @yajasi && @yajasi[:applied] %>
        <span class="correction-chip"><%= @yajasi[:label] %></span>
      <% end %>
    </div>
    <div class="correction-note">
      원래 시간: <%= @correction[:original_hour] %>시 → 보정 후: <%= @correction[:corrected_hour] %>시
      (총 <%= @correction[:total_minutes] > 0 ? '+' : '' %><%= @correction[:total_minutes] %>분)
    </div>
  </div>
<% end %>

<!-- Desktop 2-Column Grid -->
<div class="result-grid">

  <!-- LEFT COLUMN -->
  <div class="result-col-left">

    <!-- 사주 네 기둥 -->
    <section class="section-card">
      <h2 class="section-title">사주 네 기둥 <span class="term-note">사주(四柱) — 태어난 년·월·일·시의 네 기둥이에요</span></h2>
      <div class="pillars-row">
        <% pillars.each_with_index do |pillar, i| %>
          <div class="pillar-card">
            <span class="pillar-label"><%= pillar_names[i] %></span>
            <div class="pillar-char stem el-<%= element_class[pillar[:element]] %>"><%= pillar[:stem] %></div>
            <div class="pillar-char branch el-<%= element_class[SajuEngine::EarthlyBranches.element(pillar[:branch])] %>"><%= pillar[:branch] %></div>
            <span class="pillar-desc"><%= element_names[pillar[:element]] %> · <%= pillar[:yinyang] %></span>
          </div>
        <% end %>
      </div>
    </section>

    <!-- 오행 분포 -->
    <section class="section-card">
      <h2 class="section-title">오행 분포 <span class="term-note">오행(五行) — 나무·불·흙·쇠·물, 세상을 이루는 다섯 에너지</span></h2>
      <% total = distribution.values.sum.to_f %>
      <% distribution.each do |element, count| %>
        <% ratio = total > 0 ? (count / total * 100).round : 0 %>
        <div class="bar-row">
          <span class="bar-label"><%= element_icons[element] %> <%= element_names[element] %></span>
          <div class="bar-track">
            <div class="bar-fill el-bg-<%= element_class[element] %>" style="width: <%= [ratio, 4].max %>%"></div>
          </div>
          <span class="bar-value"><%= count %>개 (<%= ratio %>%)</span>
        </div>
      <% end %>
    </section>

    <!-- 용신 -->
    <section class="section-card highlight-card">
      <h2 class="section-title">용신 <span class="term-note">용신(用神) — 내 사주에서 가장 부족한 기운, 이걸 보충하면 운이 좋아져요!</span></h2>
      <div class="yongshin-box">
        <span class="yongshin-icon"><%= element_icons[saju[:yongshin][:element]] %></span>
        <div>
          <strong class="yongshin-name"><%= saju[:yongshin][:name] %>(<%= saju[:yongshin][:element] %>)</strong>
          <p class="yongshin-reason"><%= saju[:yongshin][:reason] %></p>
        </div>
      </div>
    </section>

    <!-- 대운 -->
    <section class="section-card">
      <h2 class="section-title">대운 <span class="term-note">대운(大運) — 10년 단위로 찾아오는 인생의 큰 흐름이에요</span></h2>
      <div class="daeun-grid">
        <% @major_fortune.first(6).each do |fortune| %>
          <div class="daeun-item">
            <span class="daeun-age"><%= fortune[:start_age] %>~<%= fortune[:end_age] %>세</span>
            <span class="daeun-ganzi el-<%= element_class[fortune[:element]] || 'water' %>"><%= fortune[:label] %></span>
            <span class="daeun-year"><%= fortune[:start_year] %>~<%= fortune[:end_year] %></span>
          </div>
        <% end %>
      </div>
    </section>

  </div>

  <!-- RIGHT COLUMN -->
  <div class="result-col-right">

    <!-- 십성 분석 -->
    <section class="section-card">
      <h2 class="section-title">십성 분석 <span class="term-note">십성(十星) — 나를 중심으로 주변 기운과의 관계를 나타내요</span></h2>
      <div class="tengod-row">
        <% [
          { pos: '년주', god: @ten_gods[:year_stem] },
          { pos: '월주', god: @ten_gods[:month_stem] },
          { pos: '시주', god: @ten_gods[:hour_stem] }
        ].each do |item| %>
          <% if item[:god] && SajuEngine::TenGods::GOD_DESCRIPTIONS[item[:god]] %>
            <div class="tengod-chip">
              <span class="tenod-emoji"><%= SajuEngine::TenGods::GOD_DESCRIPTIONS[item[:god]][:emoji] %></span>
              <strong><%= item[:god] %></strong>
              <span class="tenod-pos"><%= item[:pos] %></span>
            </div>
          <% end %>
        <% end %>
      </div>
      <% [
        { pos: '년주', god: @ten_gods[:year_stem] },
        { pos: '월주', god: @ten_gods[:month_stem] },
        { pos: '시주', god: @ten_gods[:hour_stem] }
      ].each do |item| %>
        <% if item[:god] && SajuEngine::TenGods::GOD_DESCRIPTIONS[item[:god]] %>
          <% desc = SajuEngine::TenGods::GOD_DESCRIPTIONS[item[:god]] %>
          <div class="info-note">
            <strong><%= desc[:emoji] %> <%= item[:god] %></strong> <span class="term-badge"><%= item[:pos] %></span><br>
            <%= desc[:meaning] %><br>
            <span class="muted">키워드: <%= desc[:keyword] %></span>
            <% if desc[:tooltip] %>
              <div class="term-tooltip"><%= desc[:tooltip] %></div>
            <% end %>
          </div>
        <% end %>
      <% end %>
    </section>

    <!-- 신살 -->
    <% if @special_stars.any? %>
      <section class="section-card">
        <h2 class="section-title">특별한 별 — 신살</h2>
        <% @special_stars.each do |star| %>
          <div class="star-row">
            <span class="star-icon"><%= star[:emoji] %></span>
            <div>
              <strong><%= star[:name] %></strong>
              <p class="muted"><%= star[:meaning] %> · <%= star[:effect] %></p>
            </div>
          </div>
        <% end %>
      </section>
    <% end %>

    <!-- 2026 트렌드 -->
    <% if @analysis[:trend_2026] %>
      <section class="section-card highlight-card">
        <h2 class="section-title">🐴 2026 병오년 <span class="term-note">올해는 '<%= @analysis[:trend_2026][:year_info][:nickname] %>' — 화(火)의 기운이 강한 해예요</span></h2>
        <p class="reading-text"><%= @analysis[:trend_2026][:general] %></p>
        <div class="divider"></div>
        <div class="info-note">
          <strong>💼 올해의 커리어 포인트</strong><br>
          <%= @analysis[:trend_2026][:career] %>
        </div>
        <div class="info-note">
          <strong>💕 올해의 연애 포인트</strong><br>
          <%= @analysis[:trend_2026][:love] %>
        </div>
        <% if @analysis[:trend_2026][:ten_god_advice] %>
          <div class="term-tooltip">
            📌 오늘의 십성 조언: <%= @analysis[:trend_2026][:ten_god_advice] %>
          </div>
        <% end %>
      </section>
    <% end %>

    <!-- 성격 & 적성 -->
    <section class="section-card">
      <h2 class="section-title">성격 & 적성</h2>
      <p class="reading-text"><%= @analysis[:personality] %></p>
    </section>

    <!-- 추천 직업 -->
    <section class="section-card">
      <h2 class="section-title">추천 직업</h2>
      <p class="reading-text"><%= @analysis[:career] %></p>
    </section>

    <!-- 연애 스타일 -->
    <section class="section-card">
      <h2 class="section-title">연애 스타일</h2>
      <p class="reading-text"><%= @analysis[:love] %></p>
    </section>

  </div>
</div>

<!-- Bottom Actions -->
<div class="action-row">
  <a href="<%= daily_fortune_path %>" class="action-btn primary">오늘의 운세 보기</a>
  <a href="<%= new_compatibility_path %>" class="action-btn secondary">궁합 보러가기</a>
  <a href="<%= new_saju_path %>" class="action-btn secondary">다시 풀어보기</a>
</div>
